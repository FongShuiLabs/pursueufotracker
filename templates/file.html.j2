        {% else %}
        <p style="font-size:14px;margin-bottom:8px">HD mirror is being prepared.</p>
        <p style="font-size:13px"><a href="https://www.war.gov/UFO/" target="_blank" rel="noopener" style="color:#52b4ff">Browse war.gov/UFO directly ↗</a></p>
        {% endif %}
      </div>
    {% endif %}
  </div>

