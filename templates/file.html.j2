<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ f.title }} | {{ site_name }}</title>
<meta name="description" content="{{ f.summary or f.title }} - {{ f.agency }} - PURSUE disclosure file.">
{% set place = (f.geo and f.geo.place) or '' %}
<meta name="keywords" content="{{ f.title }}, {{ f.agency }} UFO, {{ f.agency }} UAP, {% if event_year %}{{ event_year }} UFO sighting, {% endif %}{% if place %}{{ place }} UAP, {% endif %}PURSUE {{ f.agency }}, war.gov UFO, Trump UFO{% if event_year %} {{ event_year }}{% endif %}, declassified UAP, AARO file, {{ f.type }} UAP, Anomalousness Index">
{# Canonical points to extension-less URL - Cloudflare Pages serves it 200 direct
   while /files/X.html 308-redirects. Avoids canonical-on-redirect SEO loss. #}
{% set canonical_url = site_url ~ '/files/' ~ f.id %}
{% set og_image_abs = site_url ~ '/generated/og-cards/' ~ f.id ~ '.png' %}
<link rel="canonical" href="{{ canonical_url }}">

<meta property="og:type" content="article">
<meta property="og:title" content="{{ f.title }}">
<meta property="og:description" content="{{ f.summary or f.title }}">
<meta property="og:image" content="{{ og_image_abs }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:site_name" content="{{ site_name }}">
{% if f.date_released %}<meta property="article:published_time" content="{{ f.date_released }}T00:00:00Z">{% endif %}
<meta property="article:section" content="{{ f.agency }}">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ f.title }}">
<meta name="twitter:description" content="{{ f.summary or f.title }}">
<meta name="twitter:image" content="{{ og_image_abs }}">

<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "{% if f.type == 'video' %}VideoObject{% elif f.type == 'image' %}ImageObject{% else %}Article{% endif %}",
    "headline": {{ f.title | tojson }},
    "name": {{ f.title | tojson }},
    "description": {{ (f.summary or f.title) | tojson }},
    {% if f.type == 'video' %}"thumbnailUrl": {{ og_image_abs | tojson }},
    "contentUrl": {{ (f.video_url or f.source_url) | tojson }},
    "uploadDate": "{{ f.date_released }}T00:00:00Z",
    {% elif f.type == 'image' %}"contentUrl": {{ (f.mirror_url or f.source_url) | tojson }},
    "thumbnailUrl": {{ og_image_abs | tojson }},
    "datePublished": "{{ f.date_released }}",
    "dateModified": "{{ f.date_released }}",
    "creator": {"@type": "GovernmentOrganization", "name": "{{ f.agency }}", "url": "https://www.war.gov/"},
    "creditText": "U.S. {{ f.agency }} (via war.gov PURSUE program)",
    "copyrightNotice": "Public domain. U.S. Government work, 17 U.S.C. § 105.",
    "acquireLicensePage": "https://www.usa.gov/government-works",
    "representativeOfPage": true,
    {% else %}"image": {{ og_image_abs | tojson }},
    "datePublished": "{{ f.date_released }}",
    "dateModified": "{{ f.date_released }}",
    {% endif %}"author": { "@type": "Organization", "name": "PURSUE UFO Tracker", "url": "{{ site_url }}/" },
    "publisher": {
      "@type": "Organization",
      "name": "PURSUE UFO Tracker",
      "url": "{{ site_url }}/",
      "logo": { "@type": "ImageObject", "url": "{{ site_url }}/og-cover.svg" }
    },
    "mainEntityOfPage": {{ canonical_url | tojson }},
    "isBasedOn": {{ f.source_url | tojson }},
    "license": "https://www.usa.gov/government-works",
    "keywords": "Trump UFO files, PURSUE, UAP disclosure, {{ f.agency }}, war.gov, declassified"
  },
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": {{ f.title | tojson }},
    "creator": { "@type": "GovernmentOrganization", "name": "{{ f.agency }}" },
    "url": {{ canonical_url | tojson }},
    "datePublished": "{{ f.date_released }}",
    "license": "https://www.usa.gov/government-works"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "PURSUE Tracker", "item": "{{ site_url }}/" },
      { "@type": "ListItem", "position": 2, "name": "{{ f.agency }}", "item": "{{ site_url }}/#{{ f.category }}" },
      { "@type": "ListItem", "position": 3, "name": {{ f.title | tojson }}, "item": {{ canonical_url | tojson }} }
    ]
  }
]
</script>

<link rel="stylesheet" href="/styles.css">
{% include "partials/analytics.html.j2" %}
<style>
  .file-page{max-width:980px;margin:0 auto;padding:60px 24px}
  .breadcrumb{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:1.5px;color:#7a92b0;margin-bottom:24px}
  .breadcrumb a{color:#52b4ff;text-decoration:none}
  .file-head{display:flex;gap:24px;align-items:flex-start;margin-bottom:32px;flex-wrap:wrap}
  .file-head h1{font-size:clamp(28px,4vw,44px);color:#fff;flex:1;min-width:300px}
  .viewer{background:rgba(10,15,28,.6);border:1px solid rgba(82,180,255,.18);border-radius:10px;padding:24px;margin-bottom:32px}
  .viewer iframe,.viewer video,.viewer img{width:100%;border-radius:6px;background:#000}
  .viewer iframe{height:80vh;border:0}
  .download{display:inline-flex;align-items:center;gap:14px;background:#52b4ff;color:#04060d;padding:16px 28px;border-radius:6px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;letter-spacing:1.5px;text-decoration:none;text-transform:uppercase;box-shadow:0 0 30px rgba(82,180,255,.3)}
  .download:hover{background:#7ec8ff}
  .meta-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin:24px 0}
  .meta-item{background:rgba(82,180,255,.04);border:1px solid rgba(82,180,255,.15);padding:16px;border-radius:6px}
  .meta-item .k{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:1.5px;color:#7a92b0;text-transform:uppercase}
  .meta-item .v{color:#fff;font-size:15px;margin-top:4px;word-break:break-all}
  .score-block{background:linear-gradient(160deg,rgba(20,30,50,.6),rgba(10,15,28,.8));border:1px solid rgba(82,180,255,.18);padding:32px;border-radius:10px;margin:32px 0}
  .score-block h2{color:#fff;margin-bottom:16px}
  .score-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px dashed rgba(82,180,255,.15);font-family:'JetBrains Mono',monospace;font-size:13px}
  .score-row .name{color:#a8b8cc}
  .score-row .val{color:#52b4ff;font-weight:700}
  .transcript{background:rgba(10,15,28,.4);padding:24px;border-radius:6px;font-size:14px;color:#c0cad8;max-height:400px;overflow-y:auto;white-space:pre-wrap;border:1px solid rgba(82,180,255,.1)}
  details summary{cursor:pointer;color:#52b4ff;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:1.5px;text-transform:uppercase;padding:12px 0}
  .hash{font-family:'JetBrains Mono',monospace;font-size:11px;color:#7a92b0;word-break:break-all;background:rgba(0,0,0,.3);padding:8px 12px;border-radius:4px;border:1px solid rgba(82,180,255,.1)}
</style>
</head>
<body>
<div class="starfield"></div><div class="grid-bg"></div>

<main class="file-page">
  <div class="breadcrumb"><a href="../../index.html">PURSUE Tracker</a> &nbsp;/&nbsp; {{ f.category | upper }} &nbsp;/&nbsp; {{ f.id }}</div>

  <div class="file-head">
    <h1>{{ f.title }}</h1>
    {% if f.score and f.score.value %}
    <div class="score" style="--s:{{ f.score.value }};width:80px;height:80px"><span style="font-size:20px">{{ f.score.value }}</span></div>
    {% endif %}
  </div>

  {# Order of preference: R2 mirror > local file > video DVIDS URL > direct war.gov source #}
  {% set serve_url = f.mirror_url or (f.local_path and '../../' ~ f.local_path) or f.video_url or f.source_url %}
  {% set thumb_url = f.thumbnail_url or (f.extracted and f.extracted.thumbnail_path and '../../' ~ f.extracted.thumbnail_path) %}
  {% set caption_url = f.caption_vtt_url or (f.extracted and f.extracted.transcript_path and '../../' ~ f.extracted.transcript_path) %}

  <div class="viewer">
    {% if serve_url %}
      {% if f.type == 'pdf' %}
        <iframe src="{{ serve_url }}" title="{{ f.title }}"></iframe>
      {% elif f.type == 'video' %}
        <video controls preload="metadata"
          {% if thumb_url %}poster="{{ thumb_url }}"{% endif %}
        >
          <source src="{{ serve_url }}" type="video/mp4">
          {% if caption_url %}
          <track default kind="subtitles" srclang="en" src="{{ caption_url }}" label="English">
          {% endif %}
        </video>
      {% elif f.type == 'image' %}
        <img src="{{ serve_url }}" alt="{{ f.title }}" loading="lazy">
      {% endif %}
    {% else %}
      <div style="padding:48px;text-align:center;color:#a8b8cc">
        <p style="font-size:18px;margin-bottom:14px">📡 Mirroring in progress</p>
        <p style="font-size:14px;margin-bottom:24px">This file is indexed; the HD mirror is being prepared. Direct from war.gov:</p>
        <a href="{{ f.source_url }}" target="_blank" rel="noopener" style="background:#52b4ff;color:#04060d;padding:14px 28px;border-radius:6px;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:1.5px;text-transform:uppercase;display:inline-block">View on war.gov ↗</a>
      </div>
    {% endif %}
  </div>

  {% if f.mirror_url or f.local_path %}
  <a class="download" href="{{ serve_url }}" download>
    ⬇ Download HD{% if size_human %} ({{ size_human }}){% endif %}
  </a>
  {% elif f.source_url %}
  <a class="download" href="{{ f.source_url }}" target="_blank" rel="noopener">
    ⬇ Download from war.gov ↗{% if size_human %} ({{ size_human }}){% endif %}
  </a>
  {% endif %}

  {# Share strip - one of the biggest organic distribution levers #}
  {% set share_url = canonical_url %}
  {% set share_title = f.title ~ ' (Anomalousness Index: ' ~ ((f.score and f.score.value) or 'see methodology') ~ '/100) - PURSUE UFO Tracker' %}
  <div class="share-strip" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin:24px 0 8px;padding:14px 16px;background:rgba(82,180,255,.04);border:1px solid rgba(82,180,255,.12);border-radius:8px">
    <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#7a92b0;letter-spacing:1.5px;margin-right:4px">SHARE</span>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'reddit',surface:'file'}})" href="https://www.reddit.com/submit?url={{ share_url | urlencode }}&title={{ share_title | urlencode }}" target="_blank" rel="noopener" style="padding:6px 12px;background:rgba(255,69,0,.12);border:1px solid rgba(255,69,0,.3);border-radius:5px;color:#ff8c66;text-decoration:none;font-size:13px;font-weight:500">Reddit</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'x',surface:'file'}})" href="https://twitter.com/intent/tweet?url={{ share_url | urlencode }}&text={{ share_title | urlencode }}" target="_blank" rel="noopener" style="padding:6px 12px;background:rgba(29,161,242,.12);border:1px solid rgba(29,161,242,.3);border-radius:5px;color:#7ac6ff;text-decoration:none;font-size:13px;font-weight:500">X</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'facebook',surface:'file'}})" href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | urlencode }}" target="_blank" rel="noopener" style="padding:6px 12px;background:rgba(66,103,178,.12);border:1px solid rgba(66,103,178,.3);border-radius:5px;color:#8aaee0;text-decoration:none;font-size:13px;font-weight:500">Facebook</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'hn',surface:'file'}})" href="https://news.ycombinator.com/submitlink?u={{ share_url | urlencode }}&t={{ share_title | urlencode }}" target="_blank" rel="noopener" style="padding:6px 12px;background:rgba(255,102,0,.12);border:1px solid rgba(255,102,0,.3);border-radius:5px;color:#ff9c5c;text-decoration:none;font-size:13px;font-weight:500">HN</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'email',surface:'file'}})" href="mailto:?subject={{ share_title | urlencode }}&body={{ share_url | urlencode }}" style="padding:6px 12px;background:rgba(82,180,255,.08);border:1px solid rgba(82,180,255,.25);border-radius:5px;color:#dfe6ef;text-decoration:none;font-size:13px;font-weight:500">Email</a>
    <button onclick="navigator.clipboard.writeText('{{ share_url }}').then(()=>{this.textContent='✓ Copied';setTimeout(()=>{this.textContent='Copy link'},2000)});window.plausible&&plausible('Share',{props:{channel:'copy',surface:'file'}})" style="padding:6px 12px;background:rgba(82,180,255,.08);border:1px solid rgba(82,180,255,.25);border-radius:5px;color:#dfe6ef;font-size:13px;font-weight:500;cursor:pointer;font-family:inherit">Copy link</button>
  </div>

  <div class="meta-grid">
    <div class="meta-item"><div class="k">Agency</div><div class="v">{{ f.agency }}</div></div>
    <div class="meta-item"><div class="k">Category</div><div class="v">{{ f.category }}</div></div>
    <div class="meta-item"><div class="k">Type</div><div class="v">{{ f.type | upper }}</div></div>
    <div class="meta-item"><div class="k">Event Date</div><div class="v">{{ f.date_event or '—' }}</div></div>
    <div class="meta-item"><div class="k">Released</div><div class="v">{{ f.date_released or '—' }}</div></div>
    <div class="meta-item"><div class="k">Size</div><div class="v">{{ size_human }}</div></div>
    {% if f.geo and f.geo.place %}
    <div class="meta-item"><div class="k">Location</div><div class="v">{{ f.geo.place }}</div></div>
    {% endif %}
    {% if f.redacted %}
    <div class="meta-item"><div class="k">Status</div><div class="v">REDACTED</div></div>
    {% endif %}
  </div>

  {% if f.summary %}
  <p style="font-size:17px;color:#dfe6ef;line-height:1.7;margin:24px 0">{{ f.summary }}</p>
  {% endif %}

  {% set slot_id = "1234567890" %}{% set ad_format = "auto" %}
  {% include "partials/ad_slot.html.j2" %}

  {% if f.score and f.score.detail %}
  <div class="score-block">
    <h2>Anomalousness Index: {{ f.score.value }}/100</h2>
    <p style="color:#a8b8cc;margin-bottom:12px">Evidentiary weight that this encounter remains unexplained after conventional analysis. Not a probability of extraterrestrial origin.</p>
    <p style="display:inline-block;background:rgba(82,255,180,.08);border:1px solid rgba(82,255,180,.3);color:#52ffb4;padding:6px 12px;border-radius:4px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:1px;margin-bottom:20px">🤖 AI-ASSISTED SCORING · <a href="../../generated/verdict.html#ai" style="color:inherit;text-decoration:underline">methodology</a></p>
    {% for cname, c in f.score.detail.items() %}
    <div class="score-row">
      <span class="name">{{ cname.replace('_',' ') }} <small style="opacity:.6">({{ c.choice }})</small></span>
      <span class="val">{{ c.value }} × {{ c.weight }} = {{ c.contribution }}</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if f.extracted and f.extracted.transcript_path %}
  <details>
    <summary>📝 Transcript (Whisper-generated)</summary>
    <div class="transcript" id="transcript-target">Loading transcript...</div>
  </details>
  <script>
    fetch("../../{{ f.extracted.transcript_path }}")
      .then(r => r.text())
      .then(t => document.getElementById("transcript-target").textContent = t);
  </script>
  {% endif %}

  {% include "partials/affiliate_sidebar.html.j2" %}
  {% include "partials/support_footer.html.j2" %}

  {% if related_files %}
  <section style="margin:48px 0;padding:32px;background:rgba(82,180,255,.04);border:1px solid rgba(82,180,255,.15);border-radius:10px">
    <h3 style="color:#fff;margin-bottom:6px;font-size:20px">Related files in {{ f.agency }}</h3>
    <p style="color:#7a92b0;font-size:13px;margin-bottom:20px">Other PURSUE files in the same category, ranked by Anomalousness Index.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px">
      {% for rf in related_files %}
      <a href="{{ rf.id }}.html" style="display:block;padding:14px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.12);border-radius:6px;text-decoration:none">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#52b4ff;letter-spacing:1.5px">{{ rf.agency }} · {{ rf.type | upper }}</span>
          {% if rf.score and rf.score.value %}<span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#52ffb4;background:rgba(82,255,180,.1);padding:2px 6px;border-radius:3px">SCORE {{ rf.score.value }}</span>{% endif %}
        </div>
        <h4 style="color:#fff;font-size:14px;margin:0;line-height:1.35;font-weight:500">{{ rf.title[:90] }}{% if rf.title|length > 90 %}…{% endif %}</h4>
      </a>
      {% endfor %}
    </div>
    <p style="text-align:center;margin-top:18px"><a href="../../index.html" style="color:#52b4ff;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:1px;text-decoration:none">BROWSE ALL 161 FILES →</a></p>
  </section>
  {% endif %}

  <div style="margin-top:48px">
    <h3 style="color:#fff;margin-bottom:12px">Verification</h3>
    <p style="color:#a8b8cc;font-size:13px;margin-bottom:8px">SHA-256:</p>
    <div class="hash">{{ f.sha256 or '(awaiting HD mirror)' }}</div>
    <p style="color:#a8b8cc;font-size:13px;margin-top:16px">Source: <a href="{{ f.source_url }}" target="_blank" rel="noopener" style="color:#52b4ff">{{ f.source_url }}</a></p>
  </div>
</main>

<footer style="text-align:center;padding:60px 24px;color:#7a92b0;font-size:13px;border-top:1px solid rgba(82,180,255,.1);margin-top:60px">
  <p>Independent tracker. Not affiliated with the U.S. Department of War. <a href="../../index.html" style="color:#52b4ff">Back to tracker</a></p>
</footer>
</body>
</html>
