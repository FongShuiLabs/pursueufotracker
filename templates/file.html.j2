  {# Share strip - one of the biggest organic distribution levers #}
  {% set share_url = canonical_url %}
  {% set share_title = f.title ~ ' (Anomalousness Index: ' ~ ((f.score and f.score.value) or 'see methodology') ~ '/100) - PURSUE UFO Tracker' %}
  <div class="share-strip" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin:24px 0 8px;padding:14px 16px;background:rgba(82,180,255,.04);border:1px solid rgba(82,180,255,.12);border-radius:8px">
    <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#7a92b0;letter-spacing:1.5px;margin-right:4px">SHARE</span>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'reddit',surface:'file'}})" href="https://www.reddit.com/submit?url={{ share_url | urlencode }}&title={{ share_title | urlencode }}" target="_blank" rel="noopener" style="padding:6px 12px;background:rgba(255,69,0,.12);border:1px solid rgba(255,69,0,.3);border-radius:5px;color:#ff8c66;text-decoration:none;font-size:13px;font-weight:500">Reddit</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'x',surface:'file'}})" href="https://twitter.com/intent/tweet?url={{ share_url | urlencode }}&text={{ share_title | urlencode }}" target="_blank" rel="noopener" style="padding:6px 12px;background:rgba(29,161,242,.12);border:1px solid rgba(29,161,242,.3);border-radius:5px;color:#7ac6ff;text-decoration:none;font-size:13px;font-weight:500">X</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'facebook',surface:'file'}})" href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | urlencode }}" target="_blank" rel="noopener" style="padding:6px 12px;background:rgba(66,103,178,.12);border:1px solid rgba(66,103,178,.3);border-radius:5px;color:#8aaee0;text-decoration:none;font-size:13px;font-weight:500">Facebook</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'hn',surface:'file'}})" href="https://news.ycombinator.com/submitlink?u={{ share_url | urlencode }}&t={{ share_title | urlencode }}" target="_blank" rel="noopener" style="padding:6px 12px;background:rgba(255,102,0,.12);border:1px solid rgba(255,102,0,.3);border-radius:5px;color:#ff9c5c;text-decoration:none;font-size:13px;font-weight:500">HN</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'email',surface:'file'}})" href="mailto:?subject={{ share_title | urlencode }}&body={{ share_url | urlencode }}" style="padding:6px 12px;background:rgba(82,180,255,.08);border:1px solid rgba(82,180,255,.25);border-radius:5px;color:#dfe6ef;text-decoration:none;font-size:13px;font-weight:500">Email</a>
    <button onclick="navigator.clipboard.writeText('{{ share_url }}').then(()=>{this.textContent='✓ Copied';setTimeout(()=>{this.textContent='Copy link'},2000)});window.plausible&&plausible('Share',{props:{channel:'copy',surface:'file'}})" style="padding:6px 12px;background:rgba(82,180,255,.08);border:1px solid rgba(82,180,255,.25);border-radius:5px;color:#dfe6ef;font-size:13px;font-weight:500;cursor:pointer;font-family:inherit">Copy link</button>
  </div>

  <div class="meta-grid">
    <div class="meta-item"><div class="k">Agency</div><div class="v">{{ f.agency }}</div></div>
    <div class="meta-item"><div class="k">Category</div><div class="v">{{ f.category }}</div></div>
    <div class="meta-item"><div class="k">Type</div><div class="v">{{ f.type | upper }}</div></div>
    <div class="meta-item"><div class="k">Event Date</div><div class="v">{{ f.date_event or '—' }}</div></div>
    <div class="meta-item"><div class="k">Released</div><div class="v">{{ f.date_released or '—' }}</div></div>
    <div class="meta-item"><div class="k">Size</div><div class="v">{{ size_human }}</div></div>
    {% if f.geo and f.geo.place %}
    <div class="meta-item"><div class="k">Location</div><div class="v">{{ f.geo.place }}</div></div>
    {% endif %}
    {% if f.redacted %}
    <div class="meta-item"><div class="k">Status</div><div class="v">REDACTED</div></div>
    {% endif %}
  </div>

  {% if f.summary %}
  {% set _pr_shared = 'eight members of the U.S. House' in f.summary %}
  <p style="font-size:17px;color:#dfe6ef;line-height:1.7;margin:24px 0">{{ f.summary }}</p>
  {% if _pr_shared %}
  <p style="font-size:13px;color:#7a92b0;line-height:1.6;margin:8px 0 24px;font-style:italic">Note: war.gov publishes this same release note for all 51 Congressionally-requested DOW-UAP-PR records, so it is not specific to this file. This file's own specifics are in its title above, the video and metadata below, and the original analysis that follows.</p>
  {% else %}
  <p style="font-size:13px;color:#7a92b0;line-height:1.6;margin:8px 0 24px;font-style:italic">The summary above is sourced from the released file metadata as published to war.gov. The analysis sections below are original to this tracker.</p>
  {% endif %}
  {% endif %}

  {% set slot_id = "1234567890" %}{% set ad_format = "auto" %}
  {% include "partials/ad_slot.html.j2" %}

  {% if archive_context and archive_context.rank %}
  <section class="archive-context" style="margin:32px 0;padding:28px 30px;background:rgba(82,180,255,.04);border:1px solid rgba(82,180,255,.18);border-radius:10px">
    <h2 style="color:#fff;font-size:22px;margin:0 0 14px">Where this file fits in the PURSUE archive</h2>
    <p style="color:#dfe6ef;font-size:15.5px;line-height:1.7;margin:0 0 14px">This file is one of <strong>{{ f.agency }}'s {{ archive_context.agency_total }}</strong> files in the Trump <a href="/pursue-program" style="color:#52b4ff;text-decoration:none">PURSUE disclosure</a>. Within the {{ f.agency }} agency block it ranks <strong>#{{ archive_context.agency_rank }} of {{ archive_context.agency_total }}</strong> by Anomalousness Index. Across the entire {{ archive_context.total }}-file archive it ranks <strong>#{{ archive_context.rank }} of {{ archive_context.total }}</strong>.</p>
    {% if archive_context.tier_phrase %}
    <p style="color:#dfe6ef;font-size:15.5px;line-height:1.7;margin:0 0 14px">{{ archive_context.tier_phrase }}</p>
    {% endif %}
    {% if archive_context.topic_page %}
    <p style="color:#dfe6ef;font-size:15.5px;line-height:1.7;margin:0">For the broader cluster context, this file is part of <a href="{{ archive_context.topic_page.slug }}" style="color:#52b4ff;text-decoration:none"><strong>{{ archive_context.topic_page.name }}</strong></a> - {{ archive_context.topic_page.anchor }}. The cluster page walks through all {{ archive_context.topic_page.size }} member files with regional grouping, sensor breakdown, and standout analysis.</p>
    {% endif %}
  </section>
  {% endif %}

  {% if f.score and f.score.detail %}
  <div class="score-block">
    <h2>Anomalousness Index: {{ f.score.value }}/100</h2>
    <p style="color:#a8b8cc;margin-bottom:12px">Evidentiary weight that this encounter remains unexplained after conventional analysis. Not a probability of extraterrestrial origin - that number is not honestly computable from the released files and this tracker refuses to publish it.</p>
    <p style="display:inline-block;background:rgba(82,255,180,.08);border:1px solid rgba(82,255,180,.3);color:#52ffb4;padding:6px 12px;border-radius:4px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:1px;margin-bottom:20px">🤖 AI-ASSISTED SCORING · <a href="/verdict#ai" style="color:inherit;text-decoration:underline">methodology</a></p>
    <p style="color:#dfe6ef;font-size:14.5px;line-height:1.7;margin-bottom:24px">The six rubric components break down for this file as follows. Each component has a weighted contribution to the final score; the per-component explanation below describes what this file's particular value on that component means in the rubric's framework.</p>
    {% for cname, c in f.score.detail.items() %}
    <div style="margin-bottom:18px;padding-bottom:18px;border-bottom:1px solid rgba(82,180,255,.1)">
      <div class="score-row">
        <span class="name">{{ cname.replace('_',' ') }} <small style="opacity:.6">({{ c.choice.replace('_',' ') }})</small></span>
        <span class="val">{{ c.value }} × {{ c.weight }} = {{ c.contribution }}</span>
      </div>
      {% if score_explanations and score_explanations[cname] %}
      <p style="color:#a8b8cc;font-size:14px;line-height:1.65;margin:10px 0 0">{{ score_explanations[cname] }}</p>
      {% endif %}
    </div>
    {% endfor %}
    <p style="color:#dfe6ef;font-size:14.5px;line-height:1.7;margin:18px 0 0;padding-top:6px"><strong style="color:#fff">Bottom line on the score:</strong> the Anomalousness Index of {{ f.score.value }}/100 reflects evidentiary weight that this specific file's encounter remains structurally unexplained by the rubric's six axes - it is not a claim that the underlying event involved anything non-conventional, and it is not comparable across rubrics that use different weights. For the full per-axis weights and the rubric JSON, see <a href="/methodology" style="color:#52b4ff;text-decoration:none">/methodology</a>.</p>
  </div>
  {% endif %}

  {% if f.extracted and f.extracted.transcript_path %}
  <details>
    <summary>📝 Transcript (Whisper-generated)</summary>
    <div class="transcript" id="transcript-target">Loading transcript...</div>
  </details>
  <script>
    fetch("../../{{ f.extracted.transcript_path }}")
      .then(r => r.text())
      .then(t => document.getElementById("transcript-target").textContent = t);
  </script>
  {% endif %}

  {% include "partials/affiliate_sidebar.html.j2" %}
  {% include "partials/support_footer.html.j2" %}

  {% if series_prev or series_next %}
  <nav aria-label="File series navigation" style="display:flex;gap:12px;justify-content:space-between;margin:40px 0;padding:18px 22px;background:rgba(82,180,255,.04);border:1px solid rgba(82,180,255,.15);border-radius:8px">
    {% if series_prev %}
    <a href="/files/{{ series_prev.id }}" rel="prev" style="display:flex;align-items:center;gap:10px;color:#dfe6ef;text-decoration:none;font-size:14px;flex:1">
      <span style="font-family:'JetBrains Mono',monospace;color:#52b4ff;font-size:13px">◀ PREVIOUS</span>
      <span style="color:#a8b8cc">{{ series_prev.title[:60] }}{% if series_prev.title|length > 60 %}...{% endif %}</span>
    </a>
    {% else %}<span></span>{% endif %}
    {% if series_next %}
    <a href="/files/{{ series_next.id }}" rel="next" style="display:flex;align-items:center;gap:10px;color:#dfe6ef;text-decoration:none;font-size:14px;flex:1;justify-content:flex-end">
      <span style="color:#a8b8cc;text-align:right">{{ series_next.title[:60] }}{% if series_next.title|length > 60 %}...{% endif %}</span>
      <span style="font-family:'JetBrains Mono',monospace;color:#52b4ff;font-size:13px">NEXT ▶</span>
    </a>
    {% else %}<span></span>{% endif %}
  </nav>
  {% endif %}

  {% if related_files %}
  <section style="margin:48px 0;padding:32px;background:rgba(82,180,255,.04);border:1px solid rgba(82,180,255,.15);border-radius:10px">
    <h3 style="color:#fff;margin-bottom:6px;font-size:20px">Related files in {{ f.agency }}</h3>
    <p style="color:#7a92b0;font-size:13px;margin-bottom:20px">Other PURSUE files in the same category, ranked by Anomalousness Index.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px">
      {% for rf in related_files %}
      <a href="/files/{{ rf.id }}" style="display:block;padding:14px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.12);border-radius:6px;text-decoration:none">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#52b4ff;letter-spacing:1.5px">{{ rf.agency }} · {{ rf.type | upper }}</span>
          {% if rf.score and rf.score.value %}<span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#52ffb4;background:rgba(82,255,180,.1);padding:2px 6px;border-radius:3px">SCORE {{ rf.score.value }}</span>{% endif %}
        </div>
        <h4 style="color:#fff;font-size:14px;margin:0;line-height:1.35;font-weight:500">{{ rf.title[:90] }}{% if rf.title|length > 90 %}…{% endif %}</h4>
      </a>
      {% endfor %}
    </div>
    <p style="text-align:center;margin-top:18px"><a href="/" style="color:#52b4ff;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:1px;text-decoration:none">BROWSE ALL 222 FILES →</a></p>
  </section>
  {% endif %}

  <div style="margin-top:48px">
    <h3 style="color:#fff;margin-bottom:12px">Verification</h3>
    {% if f.sha256 %}
    <p style="color:#a8b8cc;font-size:13px;margin-bottom:8px">SHA-256{% if f.byte_verified_at %} <span style="color:#52ffb4">· verified against war.gov {{ f.byte_verified_at }}</span>{% endif %}:</p>
    <div class="hash">{{ f.sha256 }}</div>
    <p style="color:#7a92b0;font-size:12px;line-height:1.6;margin-top:8px">This hash is the SHA-256 of the file body war.gov served on the verification date above. War.gov has re-processed some file bodies since first release (re-compression + OCR, no content removed - see <a href="/changes" style="color:#52b4ff">/changes</a>); we re-verify and record the change rather than silently serve a stale hash.</p>
    {% else %}
    <p style="color:#a8b8cc;font-size:13px;margin-bottom:8px">SHA-256:</p>
    <div class="hash">(hash pending - this file type is verified on a separate schedule)</div>
    {% endif %}
    {% if f.source_url %}
    <p style="color:#a8b8cc;font-size:13px;margin-top:16px">Source: <a href="{{ f.source_url }}" target="_blank" rel="noopener" style="color:#52b4ff;word-break:break-all">{{ f.source_url }}</a></p>
    {% elif f.dvids_page_url %}
    <p style="color:#a8b8cc;font-size:13px;margin-top:16px">Source (DVIDS): <a href="{{ f.dvids_page_url }}" target="_blank" rel="noopener" style="color:#52b4ff;word-break:break-all">{{ f.dvids_page_url }}</a></p>
    {% if f.video_url %}
    <p style="color:#a8b8cc;font-size:13px;margin-top:8px">Direct video file: <a href="{{ f.video_url }}" target="_blank" rel="noopener" style="color:#52b4ff;word-break:break-all">{{ f.video_url }}</a></p>
    {% endif %}
    {% else %}
    <p style="color:#a8b8cc;font-size:13px;margin-top:16px">Source: <a href="https://www.war.gov/UFO/" target="_blank" rel="noopener" style="color:#52b4ff">war.gov/UFO</a> (specific URL not in current manifest; if the file is video-type the DVIDS page is the canonical source)</p>
    {% endif %}
  </div>
</main>

<footer style="text-align:center;padding:60px 24px;color:#7a92b0;font-size:13px;border-top:1px solid rgba(82,180,255,.1);margin-top:60px">
  <p>Independent tracker. Not affiliated with the U.S. Department of War. <a href="/" style="color:#52b4ff">Back to tracker</a></p>
</footer>
</body>
</html>
