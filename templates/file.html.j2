<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ seo_title }} | {{ site_name }}</title>
{% set _desc_score = (f.score and f.score.value) %}
{% set _desc_loc = (f.geo and f.geo.place) %}
{% set _desc_summ = (f.summary or '') | trim %}
{% set _first_sentence = (_desc_summ.split('.')[0] | trim) if _desc_summ else '' %}
{% set _desc_parts = [] %}
{% if _desc_score %}{% set _ = _desc_parts.append('Score ' ~ _desc_score ~ '/100 on the Anomalousness Index.') %}{% endif %}
{% if f.agency %}{% set _ = _desc_parts.append(f.agency ~ ' ' ~ (f.type or 'file') ~ '.') %}{% endif %}
{% if _desc_loc %}{% set _ = _desc_parts.append('Location: ' ~ _desc_loc ~ '.') %}{% endif %}
{% if f.date_event and f.date_event != 'date n/a' %}{% set _ = _desc_parts.append('Event date: ' ~ f.date_event ~ '.') %}{% endif %}
{% if _first_sentence and _first_sentence|length < 110 %}{% set _ = _desc_parts.append(_first_sentence ~ '.') %}{% endif %}
{% if f.sha256 %}{% set _ = _desc_parts.append('Indexed and SHA-256 verified against war.gov.') %}{% else %}{% set _ = _desc_parts.append('Indexed and mirrored from war.gov.') %}{% endif %}
<meta name="description" content="{{ _desc_parts | join(' ') | truncate(160, killwords=true) }}">
{% set place = (f.geo and f.geo.place) or '' %}
<meta name="keywords" content="{{ f.title }}, {{ f.agency }} UFO, {{ f.agency }} UAP, {% if event_year %}{{ event_year }} UFO sighting, {% endif %}{% if place %}{{ place }} UAP, {% endif %}PURSUE {{ f.agency }}, war.gov UFO, Trump UFO{% if event_year %} {{ event_year }}{% endif %}, declassified UAP, AARO file, {{ f.type }} UAP, Anomalousness Index">
{# Canonical points to extension-less URL - Cloudflare Pages serves it 200 direct
   while /files/X.html 308-redirects. Avoids canonical-on-redirect SEO loss. #}
{% set canonical_url = site_url ~ '/files/' ~ f.id %}
{% set og_image_abs = site_url ~ '/generated/og-cards/' ~ f.id ~ '.png' %}
<link rel="canonical" href="{{ canonical_url }}">
{% if series_prev %}<link rel="prev" href="{{ site_url }}/files/{{ series_prev.id }}">{% endif %}
{% if series_next %}<link rel="next" href="{{ site_url }}/files/{{ series_next.id }}">{% endif %}

<meta property="og:type" content="article">
<meta property="og:title" content="{{ seo_title }}">
<meta property="og:description" content="{{ f.summary or f.title }}">
<meta property="og:image" content="{{ og_image_abs }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:site_name" content="{{ site_name }}">
{% if f.date_released %}<meta property="article:published_time" content="{{ f.date_released }}T00:00:00Z">{% endif %}
<meta property="article:section" content="{{ f.agency }}">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title }}">
<meta name="twitter:description" content="{{ f.summary or f.title }}">
<meta name="twitter:image" content="{{ og_image_abs }}">

<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "{% if f.type == 'video' %}VideoObject{% elif f.type == 'image' %}ImageObject{% else %}Article{% endif %}",
    "headline": {{ seo_title | tojson }},
    "name": {{ seo_title | tojson }},
    "description": {{ (f.summary or f.title) | tojson }},
    {% if f.type == 'video' %}"thumbnailUrl": {{ og_image_abs | tojson }},
    "contentUrl": {{ (f.video_url or f.source_url) | tojson }},
    "uploadDate": "{{ f.date_released }}T00:00:00Z",
    {% elif f.type == 'image' %}"contentUrl": {{ (f.mirror_url or f.source_url) | tojson }},
    "thumbnailUrl": {{ og_image_abs | tojson }},
    "datePublished": "{{ f.date_released }}",
    "dateModified": "{{ f.date_released }}",
    "creator": {"@type": "Organization", "name": "U.S. {{ f.agency }}", "url": "https://www.war.gov/"},
    "creditText": "U.S. {{ f.agency }} (via war.gov PURSUE program)",
    "copyrightNotice": "Public domain. U.S. Government work, 17 U.S.C. § 105.",
    "acquireLicensePage": "https://www.usa.gov/government-works",
    "representativeOfPage": true,
    {% else %}"image": {{ og_image_abs | tojson }},
    "datePublished": "{{ f.date_released }}",
    "dateModified": "{{ f.date_released }}",
    {% endif %}"author": { "@type": "Organization", "name": "PURSUE UFO Tracker", "url": "{{ site_url }}/" },
    "publisher": {
      "@type": "Organization",
      "name": "PURSUE UFO Tracker",
      "url": "{{ site_url }}/",
      "logo": { "@type": "ImageObject", "url": "{{ site_url }}/og-cover.svg" }
    },
    "mainEntityOfPage": {{ canonical_url | tojson }},
    "isBasedOn": {{ f.source_url | tojson }},
    "license": "https://www.usa.gov/government-works",
    "keywords": "Trump UFO files, PURSUE, UAP disclosure, {{ f.agency }}, war.gov, declassified"
  },
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": {{ seo_title | tojson }},
    "creator": { "@type": "GovernmentOrganization", "name": "{{ f.agency }}" },
    "url": {{ canonical_url | tojson }},
    "datePublished": "{{ f.date_released }}",
    "license": "https://www.usa.gov/government-works"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "PURSUE Tracker", "item": "{{ site_url }}/" },
      { "@type": "ListItem", "position": 2, "name": "{{ f.agency }}", "item": "{{ site_url }}/#{{ f.category }}" },
      { "@type": "ListItem", "position": 3, "name": {{ seo_title | tojson }}, "item": {{ canonical_url | tojson }} }
    ]
  }
]
</script>

<link rel="stylesheet" href="/styles.css">
{% include "partials/analytics.html.j2" %}
<style>
  .file-page{max-width:980px;margin:0 auto;padding:60px 24px}
  .breadcrumb{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:1.5px;color:#7a92b0;margin-bottom:24px}
  .breadcrumb a{color:#52b4ff;text-decoration:none}
  .file-head{display:flex;gap:24px;align-items:flex-start;margin-bottom:32px;flex-wrap:wrap}
  .file-head h1{font-size:clamp(28px,4vw,44px);color:#fff;flex:1;min-width:300px}
  .viewer{background:rgba(10,15,28,.6);border:1px solid rgba(82,180,255,.18);border-radius:10px;padding:24px;margin-bottom:32px}
  .viewer iframe,.viewer video,.viewer img{width:100%;border-radius:6px;background:#000}
  .viewer iframe{height:80vh;border:0}
  .download{display:inline-flex;align-items:center;gap:14px;background:#52b4ff;color:#04060d;padding:16px 28px;border-radius:6px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;letter-spacing:1.5px;text-decoration:none;text-transform:uppercase;box-shadow:0 0 30px rgba(82,180,255,.3)}
  .download:hover{background:#7ec8ff}
  .meta-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin:24px 0}
  .meta-item{background:rgba(82,180,255,.04);border:1px solid rgba(82,180,255,.15);padding:16px;border-radius:6px}
  .meta-item .k{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:1.5px;color:#7a92b0;text-transform:uppercase}
  .meta-item .v{color:#fff;font-size:15px;margin-top:4px;word-break:break-all}
  .score-block{background:linear-gradient(160deg,rgba(20,30,50,.6),rgba(10,15,28,.8));border:1px solid rgba(82,180,255,.18);padding:32px;border-radius:10px;margin:32px 0}
  .score-block h2{color:#fff;margin-bottom:16px}
  .score-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px dashed rgba(82,180,255,.15);font-family:'JetBrains Mono',monospace;font-size:13px}
  .score-row .name{color:#a8b8cc}
  .score-row .val{color:#52b4ff;font-weight:700}
  .transcript{background:rgba(10,15,28,.4);padding:24px;border-radius:6px;font-size:14px;color:#c0cad8;max-height:400px;overflow-y:auto;white-space:pre-wrap;border:1px solid rgba(82,180,255,.1)}
  details summary{cursor:pointer;color:#52b4ff;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:1.5px;text-transform:uppercase;padding:12px 0}
  .hash{font-family:'JetBrains Mono',monospace;font-size:11px;color:#7a92b0;word-break:break-all;background:rgba(0,0,0,.3);padding:8px 12px;border-radius:4px;border:1px solid rgba(82,180,255,.1)}
</style>
</head>
<body>
<div class="starfield"></div><div class="grid-bg"></div>

<main class="file-page">
  <div class="breadcrumb"><a href="/">PURSUE Tracker</a> &nbsp;/&nbsp; {% if category_page %}<a href="/{{ category_page.slug }}/">{{ category_page.name }}</a>{% else %}{{ f.category | upper }}{% endif %} &nbsp;/&nbsp; {{ f.id }}</div>

  <div class="file-head">
    <h1>{{ f.title }}</h1>
    {% if f.score and f.score.value %}
    <div class="score" style="--s:{{ f.score.value }};width:80px;height:80px"><span style="font-size:20px">{{ f.score.value }}</span></div>
    {% endif %}
  </div>

  {# Order of preference: R2 mirror > local file > video DVIDS URL > direct war.gov source #}
  {% set serve_url = f.mirror_url or (f.local_path and '../../' ~ f.local_path) or f.video_url or f.source_url %}
  {% set thumb_url = f.thumbnail_url or (f.extracted and f.extracted.thumbnail_path and '../../' ~ f.extracted.thumbnail_path) %}
  {% set caption_url = f.caption_vtt_url or (f.extracted and f.extracted.transcript_path and '../../' ~ f.extracted.transcript_path) %}

  <div class="viewer">
    {% if serve_url %}
      {% if f.type == 'pdf' %}
        <iframe src="{{ serve_url }}" title="{{ f.title }}" loading="lazy" referrerpolicy="no-referrer"></iframe>
      {% elif f.type == 'video' %}
        <video controls preload="metadata"
          {% if thumb_url %}poster="{{ thumb_url }}"{% endif %}
        >
          <source src="{{ serve_url }}" type="video/mp4">
          {% if caption_url %}
          <track default kind="subtitles" srclang="en" src="{{ caption_url }}" label="English">
          {% endif %}
        </video>
      {% elif f.type == 'image' %}
        <img src="{{ serve_url }}" alt="{{ f.title }}" loading="lazy">
      {% endif %}
    {% else %}
      <div style="padding:48px;text-align:center;color:#a8b8cc">
        <p style="font-size:18px;margin-bottom:14px">📡 Mirroring in progress</p>
        {% if f.source_url %}
        <p style="font-size:14px;margin-bottom:24px">This file is indexed; the HD mirror is being prepared. Direct from war.gov:</p>
        <a href="{{ f.source_url }}" target="_blank" rel="noopener" style="background:#52b4ff;color:#04060d;padding:14px 28px;border-radius:6px;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:1.5px;text-transform:uppercase;display:inline-block">View on war.gov ↗</a>
        {% elif f.dvids_page_url %}
