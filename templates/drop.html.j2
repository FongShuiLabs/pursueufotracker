<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ drop.title }} - Trump PURSUE Drop {{ "%02d"|format(drop.number) }} | {{ site_name }}</title>
<meta name="description" content="{{ drop.summary[:160] }}">
{% set drop_url = site_url ~ '/drops/' ~ drop.date ~ '-drop-' ~ '%02d'|format(drop.number) %}
<link rel="canonical" href="{{ drop_url }}">

<meta property="og:type" content="article">
<meta property="og:title" content="{{ drop.title }} - Trump PURSUE Drop {{ '%02d'|format(drop.number) }}">
<meta property="og:description" content="{{ drop.summary[:200] }}">
<meta property="og:image" content="{{ site_url }}/og-cover.svg">
<meta property="og:url" content="{{ drop_url }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:image" content="{{ site_url }}/og-cover.svg">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": {{ (drop.title ~ ' - Trump PURSUE Drop ' ~ ('%02d' % drop.number)) | tojson }},
  "datePublished": "{{ drop.date }}",
  "description": {{ drop.summary | tojson }},
  "publisher": { "@type": "Organization", "name": {{ site_name | tojson }} }
}
</script>

<link rel="stylesheet" href="/styles.css">
{% include "partials/analytics.html.j2" %}
<style>
  .drop-page{max-width:980px;margin:0 auto;padding:80px 24px}
  .drop-page h1{font-size:clamp(36px,5vw,60px);color:#fff;margin-bottom:14px}
  .drop-page .lede{font-size:18px;color:#a8b8cc;margin-bottom:32px;line-height:1.6}
  .drop-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:14px;margin:32px 0}
  .drop-stats .tile{background:rgba(82,180,255,.04);border:1px solid rgba(82,180,255,.15);padding:18px;border-radius:8px;text-align:center}
  .drop-stats .n{font-family:'JetBrains Mono',monospace;font-size:24px;color:#52b4ff;font-weight:700}
  .drop-stats .l{font-size:11px;letter-spacing:1.5px;color:#7a92b0;text-transform:uppercase;margin-top:4px}
  h2{color:#52b4ff;font-size:24px;margin:48px 0 16px}
  .headline-card{display:flex;gap:16px;background:rgba(10,15,28,.6);border:1px solid rgba(82,180,255,.18);border-radius:8px;padding:20px;margin-bottom:12px;text-decoration:none;color:inherit;transition:all .2s}
  .headline-card:hover{border-color:#52b4ff;transform:translateY(-2px)}
  .headline-card h3{color:#fff;font-size:18px;margin-bottom:6px}
  .headline-card .meta{font-family:'JetBrains Mono',monospace;font-size:11px;color:#7a92b0;letter-spacing:1px}
  .headline-card .body{flex:1}
  .press-list{list-style:none}
  .press-list li{padding:10px 0;border-bottom:1px dashed rgba(82,180,255,.15)}
  .press-list a{color:#52b4ff;text-decoration:none}
  .share{margin-top:48px;padding-top:32px;border-top:1px solid rgba(82,180,255,.15);display:flex;gap:10px;flex-wrap:wrap}
  .share a{padding:10px 18px;border:1px solid rgba(82,180,255,.3);color:#52b4ff;text-decoration:none;border-radius:6px;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:1.5px;text-transform:uppercase}
  .share a:hover{background:#52b4ff;color:#04060d}
</style>
</head>
<body>
<div class="starfield"></div><div class="grid-bg"></div>

<main class="drop-page">
  <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:2px;color:#52b4ff;margin-bottom:16px"><a href="/" style="color:inherit;text-decoration:none">← PURSUE Tracker</a> &nbsp;/&nbsp; <a href="/drops/" style="color:inherit;text-decoration:none">All drops</a></p>

  <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:2px;color:#ff5757;margin-bottom:8px">DROP {{ '%02d'|format(drop.number) }} · {{ drop.date }}</p>
  <h1>{{ drop.title }}</h1>
  <p class="lede">{{ drop.summary }}</p>

  <div class="drop-stats">
    <div class="tile"><div class="n">{{ drop.file_count }}</div><div class="l">Total Files</div></div>
    <div class="tile"><div class="n">{{ drop.video_count }}</div><div class="l">Videos</div></div>
    <div class="tile"><div class="n">{{ drop.doc_count }}</div><div class="l">Documents</div></div>
    <div class="tile"><div class="n">{{ drop.image_count }}</div><div class="l">Images</div></div>
    <div class="tile"><div class="n">{{ drop.redacted_count }}</div><div class="l">Redacted</div></div>
    <div class="tile"><div class="n">{{ drop.agencies | length }}</div><div class="l">Agencies</div></div>
  </div>

  <h2>Headline files</h2>
  {% for f in headline %}
  <a class="headline-card" href="/files/{{ f.id }}">
    <div class="body">
      <div class="meta">{{ f.agency }} · {{ f.category }} · {{ f.date_event or f.date_released }}</div>
      <h3>{{ f.title }}</h3>
      <p style="color:#c0cad8;font-size:14px">{{ (f.audience or {}).tldr or f.summary or "" }}</p>
    </div>
    {% if f.score and f.score.value %}
    <div class="score" style="--s:{{ f.score.value }};width:64px;height:64px;flex-shrink:0"><span style="font-size:16px">{{ f.score.value }}</span></div>
    {% endif %}
  </a>
  {% endfor %}

  <h2>Press coverage</h2>
  <ul class="press-list">
    {% for p in drop.press_coverage %}
    <li><a href="{{ p.url }}" target="_blank" rel="noopener">{{ p.outlet }} →</a></li>
    {% endfor %}
  </ul>

  {% set share_title = 'Trump PURSUE Drop ' ~ '%02d'|format(drop.number) ~ ': ' ~ drop.title %}
  <div class="share">
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'x',surface:'drop'}})" href="https://twitter.com/intent/tweet?text={{ share_title|urlencode }}%20-%20{{ drop_url|urlencode }}" target="_blank" rel="noopener">Share on X</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'reddit',surface:'drop'}})" href="https://reddit.com/submit?url={{ drop_url|urlencode }}&title={{ share_title|urlencode }}" target="_blank" rel="noopener">Post to Reddit</a>
    <a onclick="window.plausible&&plausible('Share',{props:{channel:'hn',surface:'drop'}})" href="https://news.ycombinator.com/submitlink?u={{ drop_url|urlencode }}&t={{ share_title|urlencode }}" target="_blank" rel="noopener">Post to HN</a>
  </div>
</main>

<section style="max-width:1100px;margin:40px auto 60px;padding:32px 24px;background:rgba(82,180,255,.04);border-radius:14px;border:1px solid rgba(82,180,255,.15)">
  <p style="display:inline-block;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:1.5px;color:#52b4ff;margin-bottom:18px">MORE FROM THIS TRACKER</p>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px">
    <a href="/" style="display:block;padding:18px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.18);border-radius:8px;text-decoration:none">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#52b4ff;letter-spacing:1.5px;margin-bottom:8px">HOMEPAGE</div>
      <strong style="color:#fff;font-size:15px;display:block;margin-bottom:6px">All 222 indexed files</strong>
      <span style="color:#a8b8cc;font-size:13px;line-height:1.5">Searchable, filterable, score-ranked.</span>
    </a>
    <a href="/top-10" style="display:block;padding:18px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.18);border-radius:8px;text-decoration:none">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#52b4ff;letter-spacing:1.5px;margin-bottom:8px">CURATED</div>
      <strong style="color:#fff;font-size:15px;display:block;margin-bottom:6px">Top 10 most anomalous</strong>
      <span style="color:#a8b8cc;font-size:13px;line-height:1.5">Gemini 7 audio, Greece SWIR, Apollo 17, more.</span>
    </a>
    <a href="/verdict" style="display:block;padding:18px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.18);border-radius:8px;text-decoration:none">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#52b4ff;letter-spacing:1.5px;margin-bottom:8px">EDITORIAL</div>
      <strong style="color:#fff;font-size:15px;display:block;margin-bottom:6px">The honest verdict</strong>
      <span style="color:#a8b8cc;font-size:13px;line-height:1.5">What these files do and do not prove.</span>
    </a>
    <a href="/methodology" style="display:block;padding:18px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.18);border-radius:8px;text-decoration:none">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#52b4ff;letter-spacing:1.5px;margin-bottom:8px">METHODOLOGY</div>
      <strong style="color:#fff;font-size:15px;display:block;margin-bottom:6px">How we score every file</strong>
      <span style="color:#a8b8cc;font-size:13px;line-height:1.5">Six-axis rubric, open JSON, worked examples.</span>
    </a>
    <a href="/revisions" style="display:block;padding:18px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.18);border-radius:8px;text-decoration:none">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#52b4ff;letter-spacing:1.5px;margin-bottom:8px">CHANGE LOG</div>
      <strong style="color:#fff;font-size:15px;display:block;margin-bottom:6px">War.gov revisions</strong>
      <span style="color:#a8b8cc;font-size:13px;line-height:1.5">What changed on May 11, 2026. Full diff.</span>
    </a>
    <a href="/fbi-ufo-files/" style="display:block;padding:18px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.18);border-radius:8px;text-decoration:none">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#52b4ff;letter-spacing:1.5px;margin-bottom:8px">CATEGORY</div>
      <strong style="color:#fff;font-size:15px;display:block;margin-bottom:6px">FBI files (57)</strong>
      <span style="color:#a8b8cc;font-size:13px;line-height:1.5">Bureau case file 62-HQ-83894. 1947 to 1968.</span>
    </a>
    <a href="/military-uap-files/" style="display:block;padding:18px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.18);border-radius:8px;text-decoration:none">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#52b4ff;letter-spacing:1.5px;margin-bottom:8px">CATEGORY</div>
      <strong style="color:#fff;font-size:15px;display:block;margin-bottom:6px">Pentagon UAP (86)</strong>
      <span style="color:#a8b8cc;font-size:13px;line-height:1.5">AARO Mission Reports. 2020 to 2026.</span>
    </a>
    <a href="/faq" style="display:block;padding:18px;background:rgba(0,0,0,.25);border:1px solid rgba(82,180,255,.18);border-radius:8px;text-decoration:none">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#52b4ff;letter-spacing:1.5px;margin-bottom:8px">REFERENCE</div>
      <strong style="color:#fff;font-size:15px;display:block;margin-bottom:6px">FAQ + glossary</strong>
      <span style="color:#a8b8cc;font-size:13px;line-height:1.5">PURSUE explained, AARO, MISREP, SWIR defined.</span>
    </a>
  </div>
</section>

<footer style="text-align:center;padding:60px 24px;color:#7a92b0;font-size:13px;border-top:1px solid rgba(82,180,255,.1);margin-top:60px">
  <p><a href="/" style="color:#52b4ff">PURSUE Tracker home</a> · <a href="/drops/" style="color:#52b4ff">All drops</a> · <a href="/verdict" style="color:#52b4ff">The honest verdict</a> · <a href="/methodology" style="color:#52b4ff">Methodology</a></p>
</footer>
</body>
</html>
