    "sensor_quality": {
      "weight": 0.25,
      "scale": {
        "multi_sensor_military": 100,
        "single_sensor_military": 80,
        "civilian_aviation": 65,
        "photographic": 55,
        "eyewitness_only": 30,
        "sketch_only": 15
      }
    },
    "witness_credibility": {
      "weight": 0.20,
      "scale": {
        "trained_aviator": 90,
        "federal_agent": 90,
        "astronaut": 95,
        "military_personnel": 80,
        "law_enforcement": 70,
        "civilian_credentialed": 50,
        "civilian_anonymous": 25
      }
    },
    "corroboration": {
      "weight": 0.20,
      "scale": {
