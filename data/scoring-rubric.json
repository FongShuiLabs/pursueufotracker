        "multi_witness_single_instrument": 80,
        "single_witness_instrument": 60,
        "multi_witness_no_instrument": 50,
        "single_witness_only": 25
      }
    },
    "kinematic_anomaly": {
      "weight": 0.15,
      "scale": {
